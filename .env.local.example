# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Twitch OAuth
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
NEXT_PUBLIC_TWITCH_REDIRECT_URI=http://localhost:3000/api/auth/twitch/callback

# Resend
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App URL — localhost for local dev (Next + bot)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twitch chat → POST /api/audience-rating/chat (required for !rate bot + API)
# REQUIRED — without this line the bot exits. Same value on Vercel when you deploy.
# Generate: openssl rand -hex 24
AUDIENCE_RATING_CHAT_SECRET=paste_a_long_random_secret_here

# --- Twitch !rate bot (local) ---
# 1. AUDIENCE_RATING_CHAT_SECRET must be set (see above).
# 2. Run: npm run dev:with-chat-bot   (Next + bot)
#    Or:  npm run dev  and  npm run twitch-chat-bot  in two terminals.
# 3. Supabase: run supabase/migrations/010_audience_chat_ratings.sql once.
# 4. Optional IRC (followers/subs-only chat): TWITCH_IRC_USERNAME + TWITCH_IRC_OAUTH_TOKEN

# --- Production bot only (always-on server, not Vercel): set public app URL ---
# APP_URL=https://your-deployment.vercel.app
TWITCH_CHAT_CHANNEL=mikegtcoff
# If chat is followers-only / subs-only, use the Twitch login + access token (chat:read) for that account:
# TWITCH_IRC_USERNAME=your_login
# TWITCH_IRC_OAUTH_TOKEN=oauth:your_access_token_here
